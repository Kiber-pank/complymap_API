# Среда выполнения: development | production | test
NODE_ENV=development

# Порт HTTP-сервера (1024-65535)
PORT=3000

# Уровень логирования: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# =============================================================================
# PostgreSQL (Раздельные переменные для безопасного внедрения через Secrets)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=api_user
DB_PASSWORD=super_secure_password_here
DB_NAME=complymap_db

# Параметры пула соединений pg
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=10000